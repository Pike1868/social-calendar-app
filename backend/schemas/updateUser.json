{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "http://example.com/user-update-schema",
    "type": "object",
    "properties": {
      "first_name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 30
      },
      "last_name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 30
      },
      "display_name": {
        "type": "string",
        "maxLength": 50
      },
      "home_city": {
        "type": "string",
        "maxLength": 100
      },
      "avatar_url": {
        "type": "string",
        "maxLength": 500
      },
      "birthday": {
        "type": "string",
        "format": "date"
      },
      "time_zone": {
        "type": "string",
        "minLength": 1
      },
      "onboarding_complete": {
        "type": "boolean"
      },
      "sharing_opt_in": {
        "type": "boolean"
      }
    },
    "additionalProperties": false
  }
